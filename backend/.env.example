PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=scm_db
JWT_SECRET=your_jwt_secret_key
NODE_ENV=development

# Redis — use redis://localhost:6379 for local dev, redis://redis:6379 in Docker
# (docker-compose overrides REDIS_URL automatically via the environment block)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5500,http://localhost:3000
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key

# ─── Optional / Production ─────────────────────────────────────────────────────

# Sentry DSN — leave blank to disable error reporting
SENTRY_DSN=

# PM2 cluster instances: 'max' uses all CPU cores; set to 1 on free-tier single-core hosts
NODE_INSTANCES=max